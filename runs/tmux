#!/usr/bin/env bash

echo "🔧 Installing tmux..."

sudo apt update
sudo apt install -y tmux

echo "✅ tmux installed."

# Ensure .local/scripts exists
mkdir -p "$HOME/.local/scripts"

# Copy .tmux.conf
if [[ -f "$DEV_ENV/config-files/.tmux.conf" ]]; then
    echo "📁 Copying .tmux.conf..."
    cp "$DEV_ENV/config-files/.tmux.conf" "$HOME/.tmux.conf"
else
    echo "⚠️  No .tmux.conf found in config-files/ — skipping"
fi

# Install TPM (Tmux Plugin Manager)
if [[ ! -d "$HOME/.tmux/plugins/tpm" ]]; then
    echo "📦 Cloning TPM..."
    git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm"
else
    echo "✅ TPM already installed."
fi

# Run TPM plugin install if tmux is available
if command -v tmux >/dev/null; then
    echo "🔧 Installing tmux plugins..."
    "$HOME/.tmux/plugins/tpm/bin/install_plugins"
else
    echo "❌ tmux command not found, skipping plugin install"
fi

echo "✅ Tmux setup complete!"

